{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "mcp__git__*",
      "Bash(rm -f */.git/*.lock)",
      "Bash(rm -f /tmp/*)",
      "Bash(rm -rf node_modules/.cache/*)",
      "Bash(rm -rf */node_modules/.cache/*)",
      "Bash(rm -rf /tmp/*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm -r *)",
      "Bash(rm -rf *)"
    ]
  }
}
