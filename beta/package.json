{
  "name": "m3e-rapid-mvp",
  "private": true,
  "version": "0.1.0",
  "description": "Rapid MVP viewer with TypeScript source",
  "scripts": {
    "build": "tsc -p tsconfig.node.json && npm run build:browser",
    "build:node": "tsc -p tsconfig.node.json",
    "weekly:review": "npm run build:node && node dist/node/weekly_review_loop.js",
    "pjv34:template": "npm run build:node && node dist/node/pjv34_template_seed.js",
    "pjv34:template:run": "npm run build:node && node dist/node/pjv34_template_runner.js",
    "template:build": "npm run build:node && node dist/node/template_build_cli.js",
    "template:run": "npm run build:node && node dist/node/template_run_cli.js",
    "template:mermaid": "npm run build:node && node dist/node/template_mermaid_cli.js",
    "template:mermaid:all": "npm run build:node && node dist/node/template_mermaid_cli.js --spec-dir projects/PJ04_MermaidSystemLangGraph/templates --out tmp/pj04-mermaid-index.html",
    "template:test": "npm run build:node && npx vitest run tests/unit/template_system_builder.test.js",
    "build:browser": "tsc -p tsconfig.browser.json && tsc -p tsconfig.workbench.json && vite build --config vite.config.mjs",
    "demo:pj03": "npm run build:node && node dist/node/pj03_demo.js --mode full",
    "start": "node dist/node/start_viewer.js",
    "start:codex-app": "../scripts/beta/codex-app-server.sh",
    "test": "npm run test:unit",
    "test:unit": "npm run build:node && npx vitest run",
    "test:unit:watch": "npm run build:node && npx vitest --watch",
    "test:ci": "npm run test:unit",
    "test:visual": "playwright test",
    "test:shortcuts": "playwright test tests/visual/shortcuts.spec.js",
    "test:visual:reparent": "playwright test -g \"viewer range select multi reparent\"",
    "test:visual:selection": "playwright test -g \"viewer shift arrow expands selection\"",
    "test:visual:update": "playwright test --update-snapshots",
    "test:e2e": "playwright test --config playwright.e2e.config.js",
    "test:e2e:headed": "playwright test --config playwright.e2e.config.js --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.4.0",
    "undici-types": "^5.26.5",
    "vite": "^8.0.13",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@antv/x6": "^3.1.7",
    "@joint/core": "^4.2.4",
    "@supabase/supabase-js": "^2.103.0",
    "@types/js-yaml": "^4.0.9",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.8.0",
    "cytoscape": "^3.33.4",
    "dotenv": "^17.4.1",
    "elkjs": "^0.11.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
